# This file is entirely OPTIONAL. LightNVR runs with zero configuration:
# `docker compose up -d --build` works with no .env file at all. Everything
# below is an advanced override for power users/scripted deployments - normal
# setup (accounts, email alerts, storage, retention) all happens through the
# web UI after first boot, with no file editing required.
#
# To use any of these, copy this file to .env, uncomment what you need, and
# restart the backend container.

# Ports exposed on the host. Changing a published Docker port can only be
# done by recreating the container, so this is the one setting that
# genuinely can't move into the GUI - every Dockerized app has this same
# constraint, it isn't specific to LightNVR.
# WEB_PORT=8080
# BACKEND_PORT=8000

# Pins the JWT signing secret instead of letting it auto-generate on first
# boot. Only useful for running multiple backend instances that need to
# accept each other's tokens - a single instance doesn't need this.
# JWT_SECRET_KEY=

# Unattended admin bootstrap for scripted/headless deployments. Leave unset
# and the GUI setup wizard creates the first admin account on first visit
# instead - that's the normal path for everyone else.
# ADMIN_USERNAME=
# ADMIN_PASSWORD=

# Frontend build-time API base path. Only relevant for custom reverse-proxy
# setups that don't match the bundled nginx config; the default already
# works for the standard docker-compose.yml setup.
# VITE_API_BASE_URL=/api

# Database connection string. Infra-level setting, not exposed in the GUI on
# purpose - the running app can't safely repoint its own DB connection from
# inside itself. Must keep the +aiosqlite driver if you change this.
# DATABASE_URL=sqlite+aiosqlite:////data/lightnvr.db
