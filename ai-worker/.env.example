# Copy to .env and adjust. All optional.

# Shared secret the NVR must send as X-API-Key. Blank = no auth.
# This endpoint decodes any image posted to it, so set this unless it's on a
# network you fully trust.
AI_WORKER_API_KEY=

# Default model when the NVR doesn't name one.
# yolov8n = fastest, yolov8s/m = more accurate. On a GPU, m is still quick.
AI_WORKER_MODEL=yolov8n

# Host port to publish. Must match the address you enter in LightNVR.
AI_WORKER_PORT=8811

# Uncomment for an NVIDIA GPU (and uncomment the deploy block in
# docker-compose.yml). Needs the NVIDIA Container Toolkit on the host.
# BASE_IMAGE=pytorch/pytorch:2.4.0-cuda12.1-cudnn9-runtime
